# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL_TEST=postgresql://user:password@host/testdb?sslmode=require

# API
PORT=3000
NODE_ENV=development
API_BASE_URL=https://api.mfcb.co.bw/v1

# JWT / Auth
JWT_SECRET=change-me-min-64-chars
JWT_EXPIRY=3600
INTERNAL_HMAC_KEY=change-me-min-64-chars

# Firebase
FIREBASE_PROJECT_ID=mfcb-platform
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firestore
FIRESTORE_EMULATOR_HOST=localhost:8080

# Pub/Sub
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_CHUNK_VALIDATE_TOPIC=mfcb-chunk-validate
PUBSUB_MASTER_RECORDS_TOPIC=mfcb-master-records
PUBSUB_BATCH_COMPLETE_TOPIC=mfcb-batch-complete
PUBSUB_WEBHOOK_OUTBOUND_TOPIC=mfcb-webhook-outbound

# Cloud Storage
GCS_BUCKET_BATCHES=mfcb-batches-dev
GCS_BUCKET_QUARANTINE=mfcb-batches-quarantine-dev

# Processing
CHUNK_SIZE=500
MASTERING_CHUNK_SIZE=200
MAX_FILE_SIZE_BYTES=52428800

# Security
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# TOTP
TOTP_ISSUER=MFCB Platform
TOTP_ENCRYPTION_KEY=change-me-32-bytes-aes256-key-here

# Email / SMTP
SMTP_HOST=mail.mfcb.africa
SMTP_PORT=465
SMTP_USER=no-reply@mfcb.africa
SMTP_PASSWORD=FjfSCR4gB6em7rfFynkmTZZ44Anarw4S
EMAIL_FROM_NAME=MF Credit Bureau
EMAIL_OPS=ops@mfcb.africa
PORTAL_BASE_URL=https://portal.mfcb.africa
